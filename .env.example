# Media directory to serve (read-only mount)
MEDIA_DIR=/path/to/media

# Multi-directory support (comma-separated, optional)
# If set, overrides MEDIA_DIR. Each path must be mounted in docker-compose.yml.
# SOURCE_DIRS=/media/tv,/media/movies

# API key for authentication (optional but recommended)
API_KEY=

# TMDB API integration (optional — enriches metadata with posters, descriptions, ratings)
# Get your API key: https://www.themoviedb.org/settings/api
TMDB_API_READ_ACCESS_TOKEN=
TMDB_CACHE_TTL=86400
TMDB_LANGUAGE=en-US
